# Sway colors generated by pywal
# This file is automatically included by ~/.config/sway/colors.d/current.conf

set $bg_color        {color0}
set $text_color      {color7}
set $primary_accent  {color2}
set $border_inactive {color8}
set $border_active   {color6}

# Compatibility Aliases for 10-theme
set $primary         $primary_accent
set $surface         $bg_color
set $on_surface      $text_color

# Window Decorations - FIXED: removed extra spaces between colors
client.focused $border_active $border_active $bg_color $border_active $border_active
client.unfocused $border_inactive $border_inactive $text_color $border_inactive
